# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=bench.queue

# Redis Streams
REDIS_URL=redis://localhost:6379
REDIS_STREAM_KEY=bench:stream
REDIS_CONSUMER_GROUP=bench-group

# Benchmark defaults (override in code or extend run.ts)
BENCH_DURATION_SEC=30
BENCH_PRODUCERS=1
BENCH_CONSUMERS=1

# Degradation heuristics
DEGRADE_P95_LATENCY_MS=5000
DEGRADE_ERROR_RATE=0.01
DEGRADE_BACKLOG_GROW_SAMPLES=10
DEGRADE_SAMPLE_INTERVAL_MS=200

# Ожидание брокеров перед bench (после docker compose up)
BROKER_WAIT_TIMEOUT_MS=120000
BROKER_WAIT_INTERVAL_MS=2000
